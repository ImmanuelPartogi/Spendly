<?xml version="1.0" encoding="utf-8"?>
<!--
  Background kartu untuk homescreen widget Spendly.
  Radius 16dp mengikuti desain card di app.
  Gunakan warna putih + border abu subtle agar terlihat bersih di wallpaper apapun.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners android:radius="16dp" />

    <solid android:color="#FFFFFF" />

    <stroke
        android:width="1dp"
        android:color="#E0E6F0" />

    <!-- Shadow efek ringan via padding bawah tidak bisa di drawable,
         gunakan elevation di AppWidgetProviderInfo atau wrap dengan FrameLayout -->
</shape>